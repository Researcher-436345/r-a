# Copy to .env before docker compose up:
#   cp .env.example .env

ENVIRONMENT=local
APP_NAME=researcher-api

DATABASE_URL=postgresql+psycopg://researcher:researcher@localhost:5432/researcher
REDIS_URL=redis://localhost:6379/0

# Auth (обязательно смени JWT_SECRET вне local)
JWT_SECRET=dev-only-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

S3_ENDPOINT_URL=http://localhost:9002
S3_PUBLIC_ENDPOINT_URL=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=papers

# LLM — AITunnel (из РФ без VPN, оплата в рублях, ключ на aitunnel.ru)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.aitunnel.ru/v1
LLM_API_KEY=
LLM_MODEL=auto
LLM_TIMEOUT_SECONDS=60

# Другие варианты:
# LLM_MODEL=deepseek-v3.2
# LLM_MODEL=gemini-2.5-flash   # через AITunnel, не напрямую у Google

# OpenRouter и прямой Gemini из РФ часто блокируются
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openrouter/free
# LLM_HTTP_REFERER=http://localhost:5173
# LLM_APP_TITLE=Researcher

# Frontend
VITE_API_URL=http://localhost:8080
